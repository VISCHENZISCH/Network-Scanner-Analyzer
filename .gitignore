# ──────────────────────────────────────────────
#  NetScan Analyzer — .gitignore
#  .NET 9 / C# WinForms / Windows
# ──────────────────────────────────────────────

# Build output
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/
publish/
out/

# .NET tooling
*.user
*.suo
.vs/
.vscode/
*.swp
*.lock.json
!packages.lock.json

# NuGet
.nuget/
packages/
*.nupkg
*.snupkg

# Rider / JetBrains
.idea/
*.DotSettings.user

# OS artifacts
Thumbs.db
Desktop.ini
.DS_Store
ehthumbs.db
$RECYCLE.BIN/

# Secrets & keys — NEVER commit these
appsettings.Local.json
appsettings.Development.json
secrets.json
*.pfx
*.p12
*.key
*.pem

# LiteDB databases (scan history — can be large)
*.db
*.litedb

# PCAP captures
*.pcap
*.pcapng

# PDF / report output
reports/
exports/

# Test results
TestResults/
coverage/
*.coverage
*.coveragexml

# Publish profiles
**/Properties/PublishProfiles/

# Crash dumps
*.dmp
*.mdmp
